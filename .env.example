# ============================================
# LEA Platform - Environment Variables
# ============================================

# Database
POSTGRES_USER=lea_admin
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD_IN_PRODUCTION
POSTGRES_DB=lea_platform
# Docker services use postgres:5432. Local backend processes should use the dev
# proxy exposed by docker compose: localhost:5433.
DATABASE_URL=postgresql://lea_admin:CHANGE_THIS_PASSWORD_IN_PRODUCTION@postgres:5432/lea_platform
PRISMA_CONNECTION_LIMIT=10

# Server
NODE_ENV=development
HOST=127.0.0.1
PORT=3001
LEA_BIND_ADDR=127.0.0.1
LEA_KALI_MCP_BIND_ADDR=127.0.0.1
LEA_POSTGRES_DEV_BIND_ADDR=127.0.0.1
LEA_PGADMIN_BIND_ADDR=127.0.0.1
LEA_OAUTH_CALLBACK_BIND_ADDR=127.0.0.1

# Encryption (Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))")
ENCRYPTION_MASTER_KEY=CHANGE_THIS_TO_64_HEX_CHARACTERS

# JWT (for future authentication)
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING

# API auth
# Global API auth is opt-in. Enable only when a server-side UI proxy or
# external auth layer injects Authorization headers for browser requests.
LEA_REQUIRE_API_KEY=false
LEA_API_KEY=
# Generate a production key with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
# Set true only to acknowledge production global API auth is handled elsewhere.
LEA_ALLOW_UNAUTHENTICATED_PRODUCTION=false
# Local UI helper only. Never set this in production builds.
NEXT_PUBLIC_LEA_DEV_API_KEY=

# MVP UI feature gates. Keep disabled for the client-facing RC surface.
NEXT_PUBLIC_LEA_EXPERIMENTAL_UI=false
NEXT_PUBLIC_LEA_EXPERIMENTAL_RUNTIME_UI=false
NEXT_PUBLIC_LEA_ADVANCED_SCAN_CONTROLS=false

# CORS (Comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
LEA_ALLOW_DEV_CORS=false

# SSL (optional)
SSL_ENABLED=false
SSL_PORT=3443
SSL_KEY_PATH=./certs/server.key
SSL_CERT_PATH=./certs/server.crt
SSL_CA_PATH=

# PgAdmin (dev only)
PGADMIN_EMAIL=admin@lea-platform.com
PGADMIN_PASSWORD=CHANGE_THIS_PGADMIN_PASSWORD

# MCP Configuration
MCP_KALI_ENDPOINT=http://lea-kali-mcp:3002/mcp
MCP_TIMEOUT=30000

# Runtime extension surfaces
LEA_SKILLS_DIR=./skills
LEA_PLUGINS_DIR=./plugins
LEA_PLUGIN_TRUST_STORE=./.lea/plugin-trust.json
LEA_ENABLE_TOOL_INVOKE_API=false
LEA_TOOL_INVOKE_ALLOW=skill:*
LEA_TOOL_INVOKE_DENY=bash,shell_exec,mcp:shell_exec

# Provider Defaults
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-5-20250929

# Logging
LOG_LEVEL=info
