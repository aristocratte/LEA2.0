# ============================================
# LEA Platform - Environment Variables
# ============================================

# Database
POSTGRES_USER=lea_admin
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD_IN_PRODUCTION
POSTGRES_DB=lea_platform
DATABASE_URL=postgresql://lea_admin:CHANGE_THIS_PASSWORD_IN_PRODUCTION@postgres:5432/lea_platform

# Encryption (Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))")
ENCRYPTION_MASTER_KEY=CHANGE_THIS_TO_64_HEX_CHARACTERS

# JWT (for future authentication)
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING

# CORS (Comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# MCP Configuration
MCP_KALI_ENDPOINT=http://lea-kali-mcp:3002/mcp
MCP_TIMEOUT=30000

# Provider Defaults
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-5-20250929

# Logging
LOG_LEVEL=info
