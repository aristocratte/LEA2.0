# ============================================
# LEA Platform - Production Environment
# ============================================

# Application
NODE_ENV=production
APP_NAME=lea-platform
APP_VERSION=1.0.0

# Server
PORT=3001
HOST=0.0.0.0

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://lea_admin:your_secure_password_here@localhost:5432/lea_platform

# Direct connection string for Prisma migrations
DATABASE_DIRECT_URL=postgresql://lea_admin:your_secure_password_here@localhost:5432/lea_platform

# ============================================
# Encryption & Security
# ============================================

# Generate a secure 32-byte key (base64 encoded)
# Run: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_THIS_GENERATE_A_SECURE_32_BYTE_KEY

# JWT Secret for authentication (if needed)
JWT_SECRET=CHANGE_THIS_SECURE_JWT_SECRET

# API Keys (for external services)
# These should be stored encrypted in the database, not here

# ============================================
# MCP Configuration
# ============================================

# MCP Kali Linux Server
MCP_KALI_ENDPOINT=http://localhost:3000
MCP_KALI_TIMEOUT=30000

# MCP Connection Pool
MCP_MAX_CONNECTIONS=5
MCP_IDLE_TIMEOUT_MS=300000

# ============================================
# AI Provider Configuration
# ============================================

# Default Provider
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-5-20250929

# Provider Priority (comma-separated)
PROVIDER_PRIORITY=anthropic,zhipu,openai

# ============================================
# Logging Configuration
# ============================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log format: json, pretty
LOG_FORMAT=pretty

# Log file paths
LOG_DIR=/app/logs
ACCESS_LOG_FILE=/app/logs/access.log
ERROR_LOG_FILE=/app/logs/error.log

# ============================================
# Rate Limiting
# ============================================

# Global rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Per-IP rate limits
RATE_LIMIT_IP_MAX=50

# ============================================
# File Upload Configuration
# ============================================

# Upload directory
UPLOAD_DIR=/app/uploads

# Maximum file size (in bytes)
MAX_FILE_SIZE=104857600  # 100MB

# Allowed file types
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.xls,.xlsx,.xml,.json,.txt

# ============================================
# Pentest Configuration
# ============================================

# Maximum concurrent pentests
MAX_CONCURRENT_PENTESTS=5

# Pentest timeout (in milliseconds)
DEFAULT_PENTEST_TIMEOUT=3600000  # 1 hour

# Tool execution timeout
TOOL_EXECUTION_TIMEOUT=120000  # 2 minutes

# ============================================
# Report Generation
# ============================================

# Report templates directory
REPORT_TEMPLATES_DIR=/app/templates

# Export jobs
MAX_CONCURRENT_EXPORTS=3
EXPORT_TIMEOUT=60000  # 1 minute

# ============================================
# Monitoring & Health Checks
# ============================================

# Health check interval (milliseconds)
HEALTH_CHECK_INTERVAL=30000

# Database health check
DB_HEALTH_CHECK_TIMEOUT=5000

# Provider health check interval
PROVIDER_HEALTH_CHECK_INTERVAL=300000  # 5 minutes

# ============================================
# Development Settings (ONLY DEV)
# ============================================

# Enable debug mode
DEBUG=false

# Enable Prisma Studio (only in development)
ENABLE_PRISMA_STUDIO=false

# CORS origin (production)
CORS_ORIGIN=https://your-domain.com
