# Database
# Local backend processes connect through the docker compose dev proxy on 5433.
DATABASE_URL="postgresql://user:password@localhost:5433/lea_db"

# Server
PORT=3001
HOST=localhost

# CORS
CORS_ORIGIN="http://localhost:5173"

# AI Providers (Optional - can be configured via UI)
# ANTHROPIC_API_KEY=""
# ZHIPU_API_KEY=""
# OPENAI_API_KEY=""
# GEMINI_OAUTH_CLIENT_ID=""
# GEMINI_OAUTH_CLIENT_SECRET=""
# GEMINI_CLI_OAUTH_CLIENT_ID=""
# GEMINI_CLI_OAUTH_CLIENT_SECRET=""
# GEMINI_OAUTH_REDIRECT_URI="http://localhost:51121/oauth-callback"
# ANTIGRAVITY_CLIENT_ID=""
# ANTIGRAVITY_CLIENT_SECRET=""
# ANTIGRAVITY_REDIRECT_URI="http://localhost:51121/oauth-callback"

# Agent Swarm / Reporting Integrations
KIMI_API_KEY="your-kimi-api-key"
SYREPTOR_URL="https://sysreptor.example.com"
SYREPTOR_API_TOKEN="your-sysreptor-api-token"
SYREPTOR_DEFAULT_PROJECT_TYPE_ID="default-project-type-id"
DEFAULT_PROVIDER=zhipu
DEFAULT_MODEL=zai/glm-4.7
ZAI_API_KEY=...   # clé de ton coding plan Zhipu / Z.AI

# API Key Auth (optional — set to require Bearer token on all routes)
# LEA_API_KEY="change-me-to-a-strong-secret"

# SSL/HTTPS Configuration
SSL_ENABLED=false
SSL_PORT=3443
SSL_CERT_PATH="./certs/server.crt"
SSL_KEY_PATH="./certs/server.key"
# SSL_CA_PATH="./certs/ca.crt"  # Optional: for client certificate validation
