# ============================================
# LEA Platform - Development Environment
# ============================================

# Application
NODE_ENV=development
APP_NAME=lea-platform
APP_VERSION=1.0.0

# Server
PORT=3001
HOST=0.0.0.0

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://lea_admin:dev_password_123@localhost:5432/lea_platform

# Direct connection for Prisma
DATABASE_DIRECT_URL=postgresql://lea_admin:dev_password_123@localhost:5432/lea_platform

# ============================================
# Encryption & Security
# ============================================

# Development encryption key (NEVER use in production!)
ENCRYPTION_KEY=dGVzdGtleWZvcmRldmVsb3BtZW50b25seQ==

# Development JWT secret
JWT_SECRET=dev-jwt-secret-change-in-production

# ============================================
# MCP Configuration
# ============================================

# MCP Kali Linux Server (local development)
MCP_KALI_ENDPOINT=http://localhost:3002/mcp
MCP_TIMEOUT=30000

# MCP Connection Pool
MCP_MAX_CONNECTIONS=2
MCP_IDLE_TIMEOUT_MS=120000

# ============================================
# AI Provider Configuration
# ============================================

# Default Provider
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-5-20250929

# Provider Priority
PROVIDER_PRIORITY=anthropic,zhipu,openai

# ============================================
# Logging Configuration
# ============================================

# Log level: error, warn, info, debug
LOG_LEVEL=debug

# Log format: json, pretty
LOG_FORMAT=pretty

# Log file paths
LOG_DIR=/app/logs
ACCESS_LOG_FILE=/app/logs/access.log
ERROR_LOG_FILE=/app/logs/error.log

# ============================================
# Rate Limiting
# ============================================

# Disabled in development
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# ============================================
# File Upload Configuration
# ============================================

# Upload directory
UPLOAD_DIR=/app/uploads

# Maximum file size (in bytes)
MAX_FILE_SIZE=104857600  # 100MB

# Allowed file types
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.xls,.xlsx,.xml,.json,.txt

# ============================================
# Pentest Configuration
# ============================================

# Maximum concurrent pentests
MAX_CONCURRENT_PENTESTS=3

# Pentest timeout (in milliseconds)
DEFAULT_PENTEST_TIMEOUT=3600000  # 1 hour

# Tool execution timeout
TOOL_EXECUTION_TIMEOUT=300000  # 5 minutes

# ============================================
# Report Generation
# ============================================

# Report templates directory
REPORT_TEMPLATES_DIR=/app/templates

# Export jobs
MAX_CONCURRENT_EXPORTS=2
EXPORT_TIMEOUT=60000

# ============================================
# Monitoring & Health Checks
# ============================================

# Health check interval
HEALTH_CHECK_INTERVAL=30000

# Database health check
DB_HEALTH_CHECK_TIMEOUT=5000

# Provider health check interval
PROVIDER_HEALTH_CHECK_INTERVAL=120000  # 2 minutes

# ============================================
# Development Settings
# ============================================

# Enable debug mode
DEBUG=true

# Enable Prisma Studio
ENABLE_PRISMA_STUDIO=true

# CORS origin (allow all in development)
CORS_ORIGIN=*

# Hot reload
WATCH_MODE=true
